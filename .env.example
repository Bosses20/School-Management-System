# Django Settings
SECRET_KEY=your-secret-key-here
DEBUG=False
DJANGO_ADMIN_URL=admin
ALLOWED_HOSTS=your-domain.railway.app,localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=https://your-domain.railway.app

# Database (Railway will provide these automatically)
DB_NAME=railway
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=your-db-host
DB_PORT=5432

# Redis (Railway will provide these automatically)
REDIS_HOST=your-redis-host
REDIS_PORT=6379

# Email Settings (Optional - use a service like SendGrid)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password

# Time Zone
TIME_ZONE=UTC

# Payment Settings (Optional)
USE_PAYMENT_OPTIONS=False
USE_STRIPE=False

# Celery (Optional - for background tasks)
CELERY_BROKER_URL=redis://your-redis-host:6379/0
CELERY_RESULT_BACKEND=redis://your-redis-host:6379/0

# Monitoring (Optional)
USE_SENTRY=False
PROMETHEUS_EXPORT_MIGRATIONS=True

# Demo Environment (Optional)
IS_DEMO_ENV=False
DEMO_SUPERUSER_USERNAME=admin
DEMO_SUPERUSER_EMAIL=admin@example.com
DEMO_SUPERUSER_PASSWORD=admin123

# Mailchimp (Optional)
USE_MAILCHIMP=False